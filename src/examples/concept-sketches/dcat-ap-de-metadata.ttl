            },\n            \"dct:license\": {\n                \"@id\": \"http://dcat-ap.de/def/licenses/cc-zero\"\n            },\n            \"dct:modified\": {\n                \"@value\": \"2023-06-20T12:11:45\",\n                \"@type\": \"http://www.w3.org/2001/XMLSchema#dateTime\"\n            },\n            \"dct:title\": \" OGCAPI (GeoJSON) \"\n        },\n        {\n            \"@id\": \"https://www.landkreis-regensburg.de/buergerservice/online-services/landkreisatlas/opendata/\",\n            \"@type\": \"foaf:Organization\",\n            \"foaf:name\": \" Landkreis Regensburg\"\n        }\n    ],\n    \"@context\": {\n        \"piveau\": \"https://piveau.eu/ns/voc#\",\n        \"vcard\": \"http://www.w3.org/2006/vcard/ns#\",\n        \"dct\": \"http://purl.org/dc/terms/\",\n        \"dcat\": \"http://www.w3.org/ns/dcat#\",\n        \"rdf\": \"http://www.w3.org/1999/02/22-rdf-syntax-ns#\",\n        \"foaf\": \"http://xmlns.com/foaf/0.1/\"\n    }\n}".
