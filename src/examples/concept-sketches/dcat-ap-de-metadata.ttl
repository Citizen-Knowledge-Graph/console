    ff:hasValue "{\n    \"@graph\": [\n        {\n            \"@id\": \"https://open.bydata.de/api/hub/repo/datasets/https-lk-regensburg-bydata-de-dataset-familienstu-tzpunkte\",\n            \"dcat:theme\": {\n                \"@id\": \"http://publications.europa.eu/resource/authority/data-theme/EDUC\"\n            },\n            \"dcat:contactPoint\": {\n                \"@id\": \"_:b0\"\n            },\n            \"dct:description\": \"\\nDie Daten beinhalten die Standorte der Familienstützpunkte im Landkreis Regensburg.\\n                \",\n            \"dcat:keyword\": [\n                \" FSP \",\n                \" Familie \",\n                \" Bildung \",\n                \" Familienstützpunkte \"\n            ],\n            \"dcat:distribution\": [\n                {\n                    \"@id\": \"https://open.bydata.de/api/hub/repo/distributions/81400583-673d-4e34-abc0-bb571b510c3b\"\n                },\n                {\n                    \"@id\": \"https://open.bydata.de/api/hub/repo/distributions/3506ed61-94be-49ee-9f10-93c1a0914f4c\"\n                }\n            ],\n            \"dct:publisher\": {\n                \"@id\": \"https://www.landkreis-regensburg.de/buergerservice/online-services/landkreisatlas/opendata/\"\n            },\n            \"dct:modified\": {\n                \"@value\": \"2023-06-20T12:11:45\",\n                \"@type\": \"http://www.w3.org/2001/XMLSchema#dateTime\"\n            },\n            \"dct:issued\": {\n                \"@value\": \"2023-06-20T12:11:45\",\n                \"@type\": \"http://www.w3.org/2001/XMLSchema#dateTime\"\n            },\n            \"@type\": \"dcat:Dataset\",\n            \"piveau:openDataPresence\": \"lk-regensburg.bydata\",\n            \"dct:title\": \" Familienstützpunkte im Landkreis Regensburg \"\n        },\n        {\n            \"@id\": \"_:b0\",\n            \"vcard:fn\": \" Landkreis Regensburg \",\n            \"vcard:hasEmail\": \" gis@landratsamt-regensburg.de