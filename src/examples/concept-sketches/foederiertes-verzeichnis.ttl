ff:node1 a ff:Node;
         ff:hasClass ff:TurtleInputNode;
         ff:hasName "Top-Level-Endpunkt 1: Caritas Datenbank";
         ff:hasPosX 178;
         ff:hasPosY -494;
         ff:hasWidth 745;
         ff:hasHeight 585;
         ff:hasValue "@prefix org:     <https://civic-data.de/org/> .\n@prefix offer:   <https://civic-data.de/offer/> .\n@prefix place:   <https://civic-data.de/place/> .\n@prefix meta:   <https://civic-data.de/meta/> .\n@prefix cpsv:    <http://purl.org/vocab/cpsv#> . # Core Public Service Vocabulary\n@prefix schema:  <https://schema.org/> .\n\nmeta:this meta:source meta:caritas-db .\n\norg:caritas-berlin\n    a               schema:Organization ;\n    schema:name     \"Caritas Berlin\" ;\n    schema:url     \t<https://www.caritas-berlin.de> .\n\nplace:caritas-berlin-mitte\n    a schema:Place ;\n    schema:name \"Caritas Beratungszentrum Berlin-Mitte\" ;\n    schema:containedInPlace org:caritas-berlin .\n\noffer:erz-fam-001\n    a                     cpsv:PublicService, schema:Service ;\n    schema:serviceType    \"Erziehungs- und Familienberatung\" ;\n    schema:category       \"Soziale Beratung\" ;\n    schema:audienceType   \"Eltern\", \"Familien\", \"Kinder und Jugendliche\" ;\n\tcpsv:providedBy       org:caritas-berlin-mitte .\n\noffer:gluecksspiel-001\n    a                       cpsv:PublicService, schema:Service ;\n    schema:serviceType      \"Frühintervention Glücksspiel\" ;\n    schema:audienceType     \"Betroffene\", \"Angehörige\", \"Menschen mit Migrationserfahrung\" ;\n\toffer:openingTimes\t  \t\"Mo-Do 9:00-15:00\" ;\n\tcpsv:providedBy \t\torg:cafe-beispiellos .\n\n\n# << offer:erz-fam-001 a cpsv:PublicService >> meta:source meta:caritas-db .".
ff:node2 a ff:Node;
         ff:hasClass ff:TurtleInputNode;
         ff:hasName "Top-Level-Endpunkt 2: Der Paritätische Datenbank";
         ff:hasPosX 172;
